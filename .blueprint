updated:
    - routes/web.php
models:
    AperturaCaja: { monto_inicial: double, monto_sistema: double, monto_real: double, diferencia: double, tiempo_apertura: timestamp, tiempo_cierre: timestamp, estado: string, softdeletes: softDeletes, timestamps: timestamps, relationships: { BelongsTo: User, HasMany: MovimientoCaja } }
    MovimientoCaja: { monto: double, tipo: string, detalle: text, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: AperturaCaja } }
    Venta: { monto_pagado: double, cod_descuento: 'string nullable', monto_original: double, monto_final: double, nro_cuotas: integer, tipo_pago: string, detalle_promo_id: 'id:detalle_promo nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: User, HasMany: 'DetalleVenta, VentaCuotas, MetodoPago' } }
    DetalleVenta: { cantidad: integer, precio_original: double, descuento: double, precio_u_final: double, subtotal: double, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: 'Venta, Producto' } }
    Producto: { nombre: string, mililitros: integer, descripcion: 'text nullable', imagen: 'string nullable', codigo_barra: 'string unique', timestamps: timestamps, softdeletes: softDeletes, relationships: { HasMany: 'DetalleVenta, DetallePromo, Stock' } }
    Stock: { stock: integer, min: integer, max: integer, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: Producto } }
    Compra: { costo: double, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: 'Producto, User', HasMany: DetalleCompra } }
    DetalleCompra: { cantidad: integer, sub_costo: double, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: 'Compra, Producto' } }
    Proveedor: { nombre: string, telefono: string, descripcion: 'text nullable', timestamps: timestamps, softdeletes: softDeletes, relationships: { HasMany: Compra } }
    DetallePromo: { timestamps: timestamps, relationships: { BelongsTo: 'Producto, Promocion' } }
    Promocion: { nombre_promo: string, codigo_promo: 'string unique', descuento: double, tipo_descuento: string, fecha_inicio: date, fecha_fin: date, timestamps: timestamps, softdeletes: softDeletes, relationships: { HasMany: DetallePromo } }
    VentaCuotas: { sub_monto: double, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: Venta } }
    MetodoPago: { tipo_pago: string, timestamps: timestamps, softdeletes: softDeletes, relationships: { BelongsTo: Venta } }
